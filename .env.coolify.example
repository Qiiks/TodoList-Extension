DATABASE_URL=postgresql://user:pass@your-db-host:5432/teamtodo  # Your external PostgreSQL URL
JWT_SECRET=  # Generate with: openssl rand -hex 32
ADMIN_GITHUB_USERNAME=  # Your GitHub username for admin dashboard access
PORT=3000  # Leave as 3000, Coolify maps this to its proxy
GITHUB_CLIENT_ID=  # GitHub OAuth App Client ID
GITHUB_CLIENT_SECRET=  # GitHub OAuth App Client Secret
GITHUB_OAUTH_REDIRECT_URI=https://your-coolify-domain/api/auth/github/callback  # Must match GitHub OAuth app callback URL
WEB_APP_URL=https://your-coolify-domain  # Public URL for frontend OAuth redirects
NODE_ENV=production
